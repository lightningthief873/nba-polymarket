{erl_opts, [debug_info]}.

{project_app_dirs, ["apps/*"]}.

{deps, []}.

{plugins, [
    rebar3_cargo,
    {rebar3_proper, "0.12.1"},
    rebar3_lint,
    {covertool, "2.0.7"}
]}.

%% rebar3_cargo plugin is loaded for manual `rebar3 cargo build` invocations.
%% Automatic provider_hooks are intentionally omitted: rebar3_cargo v0.1.x
%% looks for Cargo.toml in the app directory, not in nifs/. The Makefile
%% build target runs cargo explicitly and copies the .so before rebar3 compile.
{cargo_opts, [
    {src_dirs, ["nifs/hello"]}
]}.

{dialyzer, [
    {plt_location, ".plt"},
    {plt_apps, all_deps},
    {warnings, [unmatched_returns, error_handling]}
]}.

{ct_opts, [
    {sys_config, []},
    {logdir, "_build/test/logs"}
]}.

{cover_enabled, true}.
{cover_export_enabled, true}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]},
        {cover_enabled, true}
    ]}
]}.
