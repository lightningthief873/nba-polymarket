{erl_opts, [debug_info]}.

{project_app_dirs, ["apps/*"]}.

{deps, [
    {gpb, "4.21.1"}
]}.

{plugins, [
    rebar3_cargo,
    {rebar3_gpb_plugin, "2.23.2"},
    {rebar3_proper, "0.12.1"},
    rebar3_lint,
    {covertool, "2.0.7"}
]}.

%% gpb: compile all .proto files found under the include path.
%% Output goes directly to committed source dirs so `rebar3 compile` is
%% idempotent (re-generates identical files; tracked by git diff in CI).
%% gpb_opts paths are relative to the app dir (apps/core_bus/).
%% ../../proto reaches the project-root proto/ directory.
{gpb_opts, [
    {i, "../../proto/nba_polymarket/v1"},
    {i, "../../proto"},
    {module_name_suffix, "_pb"},
    {o_erl, "../../apps/core_bus/src/generated"},
    {o_hrl, "../../apps/core_bus/include/generated"},
    maps,
    {maps_unset_optional, omitted},
    type_specs,
    {rename, {msg_name, snake_case}}
]}.

{provider_hooks, [
    {pre, [{compile, {protobuf, compile}}]}
]}.

%% rebar3_cargo plugin is loaded for manual `rebar3 cargo build` invocations.
%% Automatic provider_hooks are intentionally omitted: rebar3_cargo v0.1.x
%% looks for Cargo.toml in the app directory, not in nifs/. The Makefile
%% build target runs cargo explicitly and copies the .so before rebar3 compile.
{cargo_opts, [
    {src_dirs, ["nifs/hello"]}
]}.

{dialyzer, [
    {plt_location, ".plt"},
    {plt_apps, all_deps},
    {warnings, [unmatched_returns, error_handling]}
]}.

{ct_opts, [
    {sys_config, []},
    {logdir, "_build/test/logs"}
]}.

{cover_enabled, true}.
{cover_export_enabled, true}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]},
        {cover_enabled, true}
    ]}
]}.
