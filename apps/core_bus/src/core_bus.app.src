{application, core_bus,
 [{description, "Core event bus"},
  {vsn, "0.1.0"},
  {registered, [market_state, game_state, ingest_subscriber]},
  {mod, {core_bus_app, []}},
  {applications, [kernel, stdlib, sasl, gproc, chumak]},
  {env, [
      {zmq_host, "127.0.0.1"},
      {zmq_port, 5555}
  ]},
  {modules, []}
 ]}.
